{
  "manifest_version": 3,
  "name": "LeetSmith",
  "version": "1.0.0",
  "description": "Automatically and consistently syncs your accepted LeetCode solutions directly to your GitHub repository.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "src/content/leetcode.js"
      ]
    }
  ],
  "action": {
    "default_popup": "src/ui/popup.html",
    "default_title": "LeetSmith Status"
  },
  "options_page": "src/ui/options.html",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}