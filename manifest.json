{
    "manifest_version": 3,
    "name": "LeetSmith",
    "version": "1.0.0",
    "description": "LeetCode Github Tracker",
    "host_permissions": [
        "https://leetcode.com/*",
        "https://github.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://leetcode.com/*",
                "https://github.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "LeetSmith",
        "default_popup": "popup.html"
    }
}